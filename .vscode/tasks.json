{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "start-openocd",
            "type": "shell",
            "command": "C:\\Users\\kac\\.niiet_aspect\\riscv_kit_windows\\bin\\openocd.exe",
            "args": [
                "-s", "C:\\Users\\kac\\.niiet_aspect\\riscv_kit_windows",
                "-s", "C:\\Users\\kac\\.niiet_aspect\\riscv_kit_windows\\interface",
                "-s", "C:\\Users\\kac\\.niiet_aspect\\riscv_kit_windows\\target",
                "-f", "./interface/onboard_ftdi.cfg",
                "-f", "./target/k1921vg015.cfg",
                "-c", "init;halt",
                "-d1"
            ],
            "options": {
                "cwd": "${workspaceFolder}/vg015"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": ".",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Open On-Chip Debugger",
                    "endsPattern": "for telnet connections"
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            }
        },
        {
            "label": "bootloader-build",
            "type": "shell",
            "command": "C:\\Users\\kac\\.niiet_aspect\\riscv_kit_windows\\bin\\make.exe",
            "args": [
                "all",
                "COMPILER_PATH=C:/Users/kac/.niiet_aspect/riscv_gcc_windows/bin",
                "PREFIX=riscv64-unknown-elf-",
                "MARCH=rv32imfc_zicsr",
                "MABI=ilp32f",
                "OPTIMISATION=-O0"
            ],
            "options": {
                "cwd": "${workspaceFolder}/bootloader",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "app-build",
            "type": "shell",
            "command": "C:\\Users\\kac\\.niiet_aspect\\riscv_kit_windows\\bin\\make.exe",
            "args": [
                "all",
                "COMPILER_PATH=C:/Users/kac/.niiet_aspect/riscv_gcc_windows/bin",
                "PREFIX=riscv64-unknown-elf-",
                "MARCH=rv32imfc_zicsr",
                "MABI=ilp32f",
                "OPTIMISATION=-O0"
            ],
            "options": {
                "cwd": "${workspaceFolder}/vg015",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "bootloader-flash",
            "type": "shell",
            "command": "C:\\Users\\kac\\.niiet_aspect\\riscv_gcc_windows\\bin\\riscv64-unknown-elf-gdb.exe",
            "args": [
                "${workspaceFolder}/bootloader/build/bootloader.elf",
                "-q",
                "-batch",
                "-ex=set confirm off",
                "-ex=target extended-remote localhost:3333",
                "-ex=monitor reset halt",
                "-ex=load",
                "-ex=monitor reset run",
                "-ex=disconnect",
                "-ex=quit"
            ],
            "options": {
                "cwd": "${workspaceFolder}/bootloader"
            },
            "dependsOn": [
                "start-openocd",
                "bootloader-build"
            ],
            "dependsOrder": "sequence",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "bootloader-build-and-flash",
            "dependsOn": [
                "bootloader-flash"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "app-hex-to-bin",
            "type": "shell",
            "command": "C:\\Users\\kac\\.niiet_aspect\\riscv_gcc_windows\\bin\\riscv64-unknown-elf-objcopy.exe",
            "args": [
                "-I",
                "ihex",
                "-O",
                "binary",
                "${workspaceFolder}/vg015/build/vg015.hex",
                "${workspaceFolder}/vg015/build/vg015.bin"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "app-flash-via-bootloader-com6",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/bootloader/boot.py",
                "--port",
                "COM6",
                "--bin",
                "${workspaceFolder}/vg015/build/vg015.bin",
                "--baud",
                "115200",
                "--timeout",
                "30"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "app-hex-to-bin-and-flash-via-bootloader",
            "dependsOn": [
                "app-hex-to-bin",
                "app-flash-via-bootloader-com6"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}
