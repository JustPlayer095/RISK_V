{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "start-openocd",
            "type": "shell",
            "command": "${config:workproject.openocdExe}",
            "args": [
                "-s", "${config:workproject.openocdScriptsRoot}",
                "-s", "${config:workproject.openocdScriptsRoot}/interface",
                "-s", "${config:workproject.openocdScriptsRoot}/target",
                "-f", "${config:workproject.openocdInterfaceCfg}",
                "-f", "${config:workproject.openocdTargetCfg}",
                "-c", "${config:workproject.openocdInitCmd}",
                "-d1"
            ],
            "options": {
                "cwd": "${workspaceFolder}/vg015",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": ".",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Open On-Chip Debugger",
                    "endsPattern": "for telnet connections"
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            }
        },
        {
            "label": "start-openocd-safe",
            "type": "shell",
            "command": "${config:workproject.openocdExe}",
            "args": [
                "-s", "${config:workproject.openocdScriptsRoot}",
                "-s", "${config:workproject.openocdScriptsRoot}/interface",
                "-s", "${config:workproject.openocdScriptsRoot}/target",
                "-f", "${config:workproject.openocdInterfaceCfg}",
                "-f", "${config:workproject.openocdTargetCfg}",
                "-c", "reset_config none",
                "-c", "init",
                "-d1"
            ],
            "options": {
                "cwd": "${workspaceFolder}/vg015",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": ".",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Open On-Chip Debugger",
                    "endsPattern": "for telnet connections"
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            }
        },
        {
            "label": "bootloader-build",
            "type": "shell",
            "command": "${config:workproject.makeExe}",
            "args": [
                "all",
                "COMPILER_PATH=${config:workproject.compilerPath}",
                "PREFIX=${config:workproject.prefix}",
                "MARCH=${config:workproject.march}",
                "MABI=${config:workproject.mabi}",
                "OPTIMISATION=${config:workproject.optimisation}"
            ],
            "options": {
                "cwd": "${workspaceFolder}/bootloader",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "app-build",
            "type": "shell",
            "command": "${config:workproject.makeExe}",
            "args": [
                "all",
                "COMPILER_PATH=${config:workproject.compilerPath}",
                "PREFIX=${config:workproject.prefix}",
                "MARCH=${config:workproject.march}",
                "MABI=${config:workproject.mabi}",
                "OPTIMISATION=${config:workproject.optimisation}"
            ],
            "options": {
                "cwd": "${workspaceFolder}/vg015",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "bootloader-flash",
            "type": "shell",
            "command": "${config:workproject.gdbExe}",
            "args": [
                "${workspaceFolder}/bootloader/build/bootloader.elf",
                "-q",
                "-batch",
                "-ex=set confirm off",
                "-ex=target extended-remote localhost:3333",
                "-ex=monitor reset halt",
                "-ex=load",
                "-ex=monitor reset run",
                "-ex=disconnect",
                "-ex=quit"
            ],
            "options": {
                "cwd": "${workspaceFolder}/bootloader",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "dependsOn": [
                "start-openocd",
                "bootloader-build"
            ],
            "dependsOrder": "sequence",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "bootloader-build-and-flash",
            "dependsOn": [
                "bootloader-flash"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "app-hex-to-bin",
            "type": "shell",
            "command": "${config:workproject.objcopyExe}",
            "args": [
                "-I",
                "ihex",
                "-O",
                "binary",
                "${workspaceFolder}/vg015/build/vg015.hex",
                "${workspaceFolder}/vg015/build/vg015.bin"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "app-flash-via-bootloader",
            "type": "shell",
            "command": "${config:workproject.pythonExe}",
            "args": [
                "${workspaceFolder}/bootloader/boot.py",
                "--port",
                "${config:workproject.bootPort}",
                "--bin",
                "${workspaceFolder}/vg015/build/vg015.bin",
                "--baud",
                "${config:workproject.bootBaud}",
                "--timeout",
                "${config:workproject.bootTimeout}"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "app-hex-to-bin-and-flash-via-bootloader",
            "dependsOn": [
                "app-hex-to-bin",
                "app-flash-via-bootloader"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "debug-bootloader-safe",
            "type": "shell",
            "command": "${config:workproject.gdbExe}",
            "args": [
                "${workspaceFolder}/bootloader/build/bootloader.elf",
                "-q",
                "-batch",
                "-ex=set confirm off",
                "-ex=target extended-remote localhost:3333",
                "-ex=monitor halt",
                "-ex=load"
            ],
            "options": {
                "cwd": "${workspaceFolder}/bootloader",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "dependsOn": [
                "start-openocd-safe",
                "bootloader-build"
            ],
            "dependsOrder": "sequence",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "debug-app-attach-safe",
            "type": "shell",
            "command": "${config:workproject.gdbExe}",
            "args": [
                "${workspaceFolder}/vg015/build/vg015.elf",
                "-q",
                "-batch",
                "-ex=set confirm off",
                "-ex=target extended-remote localhost:3333",
                "-ex=monitor halt"
            ],
            "options": {
                "cwd": "${workspaceFolder}/vg015",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "dependsOn": [
                "start-openocd-safe"
            ],
            "dependsOrder": "sequence",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
