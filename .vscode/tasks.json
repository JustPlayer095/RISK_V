{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "start-openocd",
            "type": "shell",
            "command": "${env:OPENOCD_EXE}",
            "args": [
                "-s", "${env:OPENOCD_SCRIPTS_ROOT}",
                "-s", "${env:OPENOCD_SCRIPTS_ROOT}/interface",
                "-s", "${env:OPENOCD_SCRIPTS_ROOT}/target",
                "-f", "./interface/onboard_ftdi.cfg",
                "-f", "./target/k1921vg015.cfg",
                "-c", "init;halt",
                "-d1"
            ],
            "options": {
                "cwd": "${workspaceFolder}/${input:appProjectDir}"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": ".",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Open On-Chip Debugger",
                    "endsPattern": "for telnet connections"
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            }
        },
        {
            "label": "bootloader-build",
            "type": "shell",
            "command": "${env:MAKE_EXE}",
            "args": [
                "all",
                "COMPILER_PATH=${env:COMPILER_PATH}",
                "PREFIX=riscv64-unknown-elf-",
                "MARCH=rv32imfc_zicsr",
                "MABI=ilp32f",
                "OPTIMISATION=-O0"
            ],
            "options": {
                "cwd": "${workspaceFolder}/bootloader",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "app-build",
            "type": "shell",
            "command": "${env:MAKE_EXE}",
            "args": [
                "all",
                "COMPILER_PATH=${env:COMPILER_PATH}",
                "PREFIX=riscv64-unknown-elf-",
                "MARCH=rv32imfc_zicsr",
                "MABI=ilp32f",
                "OPTIMISATION=-O0"
            ],
            "options": {
                "cwd": "${workspaceFolder}/${input:appProjectDir}",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "bootloader-flash",
            "type": "shell",
            "command": "${env:GDB_EXE}",
            "args": [
                "${workspaceFolder}/bootloader/build/bootloader.elf",
                "-q",
                "-batch",
                "-ex=set confirm off",
                "-ex=target extended-remote localhost:3333",
                "-ex=monitor reset halt",
                "-ex=load",
                "-ex=monitor reset run",
                "-ex=disconnect",
                "-ex=quit"
            ],
            "options": {
                "cwd": "${workspaceFolder}/bootloader"
            },
            "dependsOn": [
                "start-openocd",
                "bootloader-build"
            ],
            "dependsOrder": "sequence",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "bootloader-build-and-flash",
            "dependsOn": [
                "bootloader-flash"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "setup-toolchain-paths",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/tools/setup_toolchain_env.ps1"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "app-hex-to-bin",
            "type": "shell",
            "command": "${env:OBJCOPY_EXE}",
            "args": [
                "-I",
                "ihex",
                "-O",
                "binary",
                "${workspaceFolder}/${input:appProjectDir}/build/${input:appProjectName}.hex",
                "${workspaceFolder}/${input:appProjectDir}/build/${input:appProjectName}.bin"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "app-flash-via-bootloader",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/bootloader/boot.py",
                "--port",
                "auto",
                "--bin",
                "${workspaceFolder}/${input:appProjectDir}/build/${input:appProjectName}.bin",
                "--baud",
                "115200",
                "--timeout",
                "30"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "app-hex-to-bin-and-flash-via-bootloader",
            "dependsOn": [
                "app-hex-to-bin",
                "app-flash-via-bootloader"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "appProjectDir",
            "type": "promptString",
            "description": "Папка проекта основного приложения (относительно workspace)",
            "default": "vg015"
        },
        {
            "id": "appProjectName",
            "type": "promptString",
            "description": "Имя выходного файла приложения (без расширения)",
            "default": "vg015"
        }
    ]
}
